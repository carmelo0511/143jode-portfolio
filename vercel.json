{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build/fetch-content.mjs",
  "outputDirectory": ".",
  "cleanUrls": false,
  "headers": [
    {
      "source": "/data.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ]
}
